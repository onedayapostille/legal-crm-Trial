# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env  (cp .env.example .env)  and fill in real values.
# .env is git-ignored and is NEVER committed. All secrets are read from the
# environment only — they are never hard-coded in source or the Docker image.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string. REQUIRED — the app fails on every DB request
# until this is set (e.g. the login page error "DATABASE_URL ... is required").
#   Local Postgres:   postgresql://USER:PASSWORD@localhost:5432/legal_crm
#   Managed/remote:   append ?sslmode=require   (e.g. Supabase, RDS, Neon)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Long random secret used to sign JWT session cookies. REQUIRED in production.
# Generate with: openssl rand -hex 32
JWT_SECRET=local-dev-secret-change-later
# AUTH_SECRET is also supported as a fallback for JWT_SECRET.
AUTH_SECRET=local-dev-secret-change-later

# Public application URL for the deployed CRM.
APP_URL=http://localhost:3000

# Optional API origin when frontend and API are hosted on different origins.
# Leave blank for same-origin deployments.
API_BASE_URL=

# Initial admin seed. Required only before first user is created.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin

# Server
PORT=3000
# `pnpm dev` forces NODE_ENV=development (Vite dev server) regardless of this
# value; `pnpm start` runs in production. Leave as production for deployments.
NODE_ENV=development

# Optional file storage (S3 compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Optional email provider
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
