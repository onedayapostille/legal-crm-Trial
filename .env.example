# Required

# PostgreSQL connection string.
# Example: postgresql://USER:PASSWORD@HOST:5432/legal_crm?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/legal_crm

# Long random secret used to sign JWT session cookies.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-use-a-long-random-secret-in-production
# AUTH_SECRET is also supported as a fallback for JWT_SECRET.
AUTH_SECRET=

# Public application URL for the deployed CRM.
APP_URL=https://crm.alghazzawi.com

# Optional API origin when frontend and API are hosted on different origins.
# Leave blank for same-origin deployments.
API_BASE_URL=

# Initial admin seed. Required only before first user is created.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password-123
ADMIN_NAME=System Administrator

# Server
PORT=3000
NODE_ENV=production

# Optional file storage (S3 compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Optional email provider
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
