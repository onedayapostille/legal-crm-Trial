# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env  (cp .env.example .env)  and fill in real values.
# .env is git-ignored and is NEVER committed. All secrets are read from the
# environment only — they are never hard-coded in source or the Docker image.
#
# DEPLOYMENT (hosted website/app): do NOT put real values in this file or in
# docker-compose.yml. Add the real values in your hosting platform's
# Environment Variables settings (App Settings → Edit Environment Variables),
# then Save & Redeploy so the running container picks them up. The compose file
# only references these names as ${PLACEHOLDERS}; the platform supplies values.
#
# Minimum required runtime variables in deployment:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
#   JWT_SECRET=<secure-random-secret>     # generate: openssl rand -hex 32
#   NODE_ENV=production
#
# Verify the running container actually received them (no secrets are exposed):
#   curl https://<your-app>/health   →   { "databaseUrlSet": true, "jwtSecretSet": true }
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string. REQUIRED — the app fails on every DB request
# until this is set (e.g. the login page error "DATABASE_URL ... is required").
#   Local Postgres:   postgresql://USER:PASSWORD@localhost:5432/legal_crm
#   Managed/remote:   append ?sslmode=require   (e.g. Supabase, RDS, Neon)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Long random secret used to sign JWT session cookies. REQUIRED in production.
# Generate with: openssl rand -hex 32
JWT_SECRET=local-dev-secret-change-later
# AUTH_SECRET is also supported as a fallback for JWT_SECRET.
AUTH_SECRET=local-dev-secret-change-later

# Public application URL for the deployed CRM.
APP_URL=http://localhost:3000

# Optional API origin when frontend and API are hosted on different origins.
# Leave blank for same-origin deployments.
API_BASE_URL=

# Initial admin seed. Required only before first user is created.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin

# Server
PORT=3000
# `pnpm dev` forces NODE_ENV=development (Vite dev server) regardless of this
# value; `pnpm start` runs in production. Leave as production for deployments.
NODE_ENV=development

# Optional file storage (S3 compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Optional email provider
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ── NVIDIA AI Assistant (server-side only) ────────────────────────────────────
# Powers the internal AI Management Assistant via NVIDIA NIM Chat Completions.
# SERVER-SIDE ONLY: never prefix these with VITE_/NEXT_PUBLIC_/REACT_APP_ — that
# would ship the key to the browser. The key is read from process.env on the
# backend only and is never returned to the client, logged, or baked into the
# image. Leave NVIDIA_API_KEY blank here; put the REAL key in .env locally and in
# your hosting platform's Environment Variables in production (then redeploy).
NVIDIA_API_KEY=<PASTE_NVIDIA_API_KEY_HERE>
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=google/diffusiongemma-26b-a4b-it
